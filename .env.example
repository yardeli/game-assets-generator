# Game Assets Generator - Environment Configuration
# Local 2D-to-3D Pipeline (No external APIs required!)

# API Keys (optional - not needed for local generation)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Database
DATABASE_URL=sqlite:///./assets.db

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Storage (auto-created)
OUTPUT_DIR=./outputs

# Generation Settings
MAX_GENERATION_TIME=300
TORCH_DEVICE=cuda  # or cpu

# Notes:
# - This uses local Stable Diffusion + depth mapping
# - No API keys required to start generating!
# - First run will download ~4GB of models (~5 min)
# - Requires GPU for fast generation (CPU also works, slower)
