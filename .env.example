# Game Assets Generator - Environment Configuration

# API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
MESHY_API_KEY=your-meshy-api-key-here
TRIPO_API_KEY=your-tripo-api-key-here

# Database
DATABASE_URL=sqlite:///./assets.db

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# CrewAI Configuration
CREWAI_MODEL=gpt-4
CREWAI_VERBOSE=True

# Storage
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# Feature Flags
ENABLE_MESHY=True
ENABLE_TRIPO=False
MAX_GENERATION_TIME=300
